# Server-side only — set in Netlify → Site settings → Environment variables.
# Powers the "help me say this" letter assist. NEVER exposed to the browser.
ANTHROPIC_API_KEY=

# Server-side only — powers the "Partner with us" contact form. Set ONE of the
# two options below in Netlify. Until one is set, the form falls back to
# opening the visitor's own email app.
#
# Option A (no DNS needed) — Web3Forms. Create a free access key at
# web3forms.com bound to debi@sparcsolutions.org, then set it here. Preferred
# when you can't add DNS records.
WEB3FORMS_ACCESS_KEY=
#
# Option B — Resend. Requires verifying the sending domain in DNS (SPF/DKIM),
# so only use this if you have DNS access. PARTNER_FROM must be on the verified
# domain. Ignored when WEB3FORMS_ACCESS_KEY is set.
# RESEND_API_KEY=
# PARTNER_INBOX=debi@sparcsolutions.org
# PARTNER_FROM=Accessibility in Real Time <partners@sparcsolutions.org>

# Public — safe in the browser; RLS protects the data.
NEXT_PUBLIC_SUPABASE_URL=https://ldxpockcgcxvsrbyhcnt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_3tn2UadRVekIf5Pw6F5z-A_40ZbdvTm
